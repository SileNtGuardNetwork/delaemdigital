# Public (client-safe)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# Dev only: mock form submit without Supabase (default: false)
NEXT_PUBLIC_LEAD_FORM_MOCK=false

# Server-only — set in .env.local, never commit secrets
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram owner notification (outbound only, not a full bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
# Set to false to disable Telegram while keeping Supabase
TELEGRAM_NOTIFICATIONS_ENABLED=true
